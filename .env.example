# JMIE Environment Configuration Template
# Copy this to .env.dev (dev) or .env.prod (production) and fill in real values

# === Deployment Environment ===
ENV=development  # Options: development, production

# === Oracle Cloud VM ===
ORACLE_VM_IP=YOUR_ORACLE_VM_PUBLIC_IP
ORACLE_VM_SSH_KEY=/path/to/ssh/key

# === AWS S3 Configuration ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=jmie-datalake
S3_LIFECYCLE_DAYS_TO_IA=30
S3_LIFECYCLE_DAYS_TO_DELETE=90

# === AWS CloudWatch ===
CLOUDWATCH_METRICS_ENABLED=true
CLOUDWATCH_NAMESPACE=JMIE

# === GCP Artifact Registry ===
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
GCP_ARTIFACT_REGISTRY_REPO=jmie
GCP_SA_KEY_JSON=/path/to/gcp/key.json

# === PostgreSQL — Application DB ===
POSTGRES_HOST=postgres-app
POSTGRES_PORT=5432
POSTGRES_USER=jmie_user
POSTGRES_PASSWORD=secure_random_password
POSTGRES_DB=jmie_db

# === PostgreSQL — Airflow Metadata DB ===
POSTGRES_AIRFLOW_HOST=postgres-airflow
POSTGRES_AIRFLOW_PORT=5433
POSTGRES_AIRFLOW_USER=airflow_user
POSTGRES_AIRFLOW_PASSWORD=secure_random_password
POSTGRES_AIRFLOW_DB=airflow_db

# === Qdrant Vector Database ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=  # Leave empty for development; set for production

# === MLflow ===
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql://jmie_user:secure_random_password@postgres-app:5432/mlflow_db
MLFLOW_ARTIFACT_ROOT=/data/mlflow_artifacts  # Or s3://jmie-datalake/mlflow in prod

# === Arize Phoenix ===
PHOENIX_HOST=phoenix
PHOENIX_PORT=6006
PHOENIX_ENABLED=true
PHOENIX_ENVIRONMENT=development  # Options: development, production

# === FastAPI Configuration ===
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_DEBUG=true  # Set to false in production
FASTAPI_LOG_LEVEL=INFO
API_TITLE=JMIE API

# === API Authentication ===
API_KEY_HASH_ALGORITHM=bcrypt
API_KEY_EXPIRATION_DAYS=365

# === Language Detection ===
DEFAULT_LANGUAGE=en

# === Data Scraper Configuration ===
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_FACTOR=2.0
SCRAPER_RATE_LIMIT_DELAY=1.0  # seconds between requests per source
JMIE_USE_MOCK_SCRAPER=false  # Set to true in development to use mock data instead of live scraping

# === Airflow Configuration ===
AIRFLOW_HOME=/home/airflow/gitsync
AIRFLOW__CORE__DAGS_FOLDER=/home/airflow/gitsync/dags
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__EXECUTOR=SequentialExecutor  # LocalExecutor or SequentialExecutor for dev
AIRFLOW__CORE__LOG_LEVEL=INFO
AIRFLOW__CORE__PLUGINS_FOLDER=/home/airflow/gitsync/plugins
AIRFLOW__CORE__MAX_MAP_LENGTH=128
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://airflow_user:secure_random_password@postgres-airflow:5433/airflow_db
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_generated_with_python_c_lib_cryptography

# === Airflow Email / Slack Alerting ===
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_USER=your_email@example.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_email_password
AIRFLOW__SMTP__SMTP_FROM=airflow@jmie.example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL  # Optional

# === NLP Configuration ===
NER_MODEL_NAME=xlm-roberta-base
NER_BATCH_SIZE=32
NER_MAX_LENGTH=512
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_OUTPUT_DIM=768

# === RAG Configuration ===
RAG_RETRIEVAL_TOP_K=10
RAG_CONTEXT_WINDOW_TOKENS=2000
RAG_ENABLE_SYNTHESIS=true
RAG_SYNTHESIS_MODEL=all-MiniLM-L6-v2  # Placeholder; use LLM API in production

# === Frontend Configuration ===
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=Job Market Intelligence Engine
VITE_ENABLE_PHOENIX=true
VITE_PHOENIX_URL=http://localhost:6006

# === Node.js Environment (for frontend development) ===
NODE_ENV=development

# === Testing Configuration ===
PYTEST_ADDOPTS=--tb=short -v
TEST_DATABASE_URL=postgresql://jmie_user:secure_random_password@postgres-app:5432/jmie_test

# === Logging and Monitoring ===
LOG_FORMAT=json  # json or human
LOG_LEVEL=INFO
SENTRY_DSN=  # Optional: sentry.io error tracking

# === Feature Flags ===
FEATURE_ENABLE_RAG_SYNTHESIS=true
FEATURE_ENABLE_SKILL_COOCCURRENCE=true
FEATURE_ENABLE_TREND_EXPORT=true
