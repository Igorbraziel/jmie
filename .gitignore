################################################################################
# EXCEPTIONS (files/folders that SHOULD be committed)
################################################################################
# These are marked with ! to be exceptions to previous ignore rules

# Example environment files (with fake credentials)
!.env.example
!.env.dev.example
!.env.*.example

# Keep all source code
!src/
!api/
!scraper/
!nlp/
!dags/
!frontend/
!db/

# Keep configuration files
!.github/
!.gitignore
!.dockerignore
!.editorconfig

# Keep documentation
!docs/
!README.md
!CLAUDE.md
!CONTRIBUTING.md

# Keep CI/CD workflows
!.github/workflows/

# Keep test directories
!tests/
!test_fixtures/

# Keep placeholders
!.gitkeep

# Keep infrastructure code
!infrastructure/

# Keep Docker files
!Dockerfile
!docker-compose*.yml

# Keep project files
!pyproject.toml
!uv.lock
!package.json
!tsconfig.json
!vite.config.ts

################################################################################
# END OF .gitignore
################################################################################
